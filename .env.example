# JB LocalGuard OS — 환경변수 예시
#
# 모든 키는 선택사항입니다. 아무것도 설정하지 않아도 앱은 결정론적 오프라인
# 시뮬레이션(fallback)으로 전체 데모를 완주합니다 — 심사·시연에 키가 필요하지 않습니다.
#
# 사용법: cp .env.example .env 후 필요한 값만 채우고, 셸에서 export 하거나
# `MOLIT_SERVICE_KEY=... npm run demo:proxy` 처럼 커맨드 앞에 직접 지정하세요.

## ── 실거래가 라이브 데모 (선택, ?live=1 · npm run demo:proxy) ──────────────
## data.go.kr(국토부) Decoding 키. 아래 공용 키 하나만 채워도 7개 dataset에 모두 적용됨.
MOLIT_SERVICE_KEY=
MOLIT_API_KEY=
PUBLIC_DATA_API_KEY=
DATA_GO_KR_KEY=

## dataset별 전용 키 (공용 키보다 우선 적용, 선택)
MOLIT_APT_TRADE_KEY=
MOLIT_APT_RENT_KEY=
MOLIT_ROW_HOUSE_TRADE_KEY=
MOLIT_ROW_HOUSE_RENT_KEY=
MOLIT_DETACHED_HOUSE_TRADE_KEY=
MOLIT_DETACHED_HOUSE_RENT_KEY=
MOLIT_OFFICETEL_RENT_KEY=

## 서울 열린데이터광장 키 (전세보호 시세 보강, 선택)
SEOUL_OPEN_API_KEY=
SEOUL_API_KEY=
MOVEVALUE_SEOUL_OPEN_API_KEY=

## ── 로컬 모델 (선택, npm run demo:ollama) ──────────────────────────────
## Ollama 미기동 시 앱은 모의(mock) 에이전트 출력으로 대체됩니다.
OLLAMA_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_AGENT_PROXY_PORT=8030
OLLAMA_TIMEOUT_MS=20000

## ── 백엔드·저장소 (선택, npm run backend) ──────────────────────────────
## 기본 저장소는 로컬 JSON 파일(server/data/localguard-db.json)이라 아래 값 없이도 동작합니다.
JB_DB_DRIVER=json
JB_BACKEND_DB=
JB_STATIC_ROOT=
JB_PUBLIC_DATA_PROXY=http://127.0.0.1:8020
JB_OLLAMA_PROXY=http://127.0.0.1:8030
PORT=8010
JB_BACKEND_PORT=8010

## Supabase로 전환할 때만 필요 (server/sql/supabase-api-state.sql 적용 후)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
JB_SUPABASE_URL=
JB_SUPABASE_SERVICE_ROLE_KEY=
JB_SUPABASE_TABLE=jb_backend_state
JB_SUPABASE_STATE_ID=localguard

## ── 개발·테스트 잡변수 (선택) ───────────────────────────────────────────
NODE_ENV=
E2E_PORT=
CI=
